# Copy this file to .streamlit/secrets.toml and fill in your Snowflake values.
# Do not upload the real secrets.toml file to GitHub.

[snowflake]
account = "your_account_identifier"
user = "your_username"
password = "your_password"
warehouse = "COMPUTE_WH"
database = "MOVIES_CDC_DB"
schema = "MOVIES_CDC_SCHEMA"
role = "ACCOUNTADMIN"
